{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "OPC": "Information"
    },
    "File": {
      "Path": "logs/computehub-opc-{Date}.log",
      "FileSizeLimitBytes": 10485760,
      "RetainedFileCountLimit": 31,
      "RollingInterval": "Day"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
      }
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1AndHttp2"
      },
      "OpcUa": {
        "Url": "opc.tcp://0.0.0.0:4840",
        "Protocols": "Http1AndHttp2"
      }
    },
    "Limits": {
      "MaxConcurrentConnections": 200,
      "MaxConcurrentUpgradedConnections": 100,
      "MaxRequestBodySize": 10485760,
      "MaxResponseBufferSize": 10485760,
      "KeepAliveTimeout": 120,
      "RequestHeadersTimeout": 30
    },
    "AddServerHeader": false
  },
  "OPC": {
    "ServerName": "ComputeHub-OPC-Server",
    "ApplicationUri": "urn:computehub:opc:server",
    "ProductUri": "https://computehub.com/opc-server",
    "ApplicationName": "ComputeHub OPC UA Server",
    "ApplicationType": "Server",
    "DiscoveryUrls": [
      "opc.tcp://localhost:4840",
      "opc.tcp://{hostname}:4840",
      "opc.tcp://{ipaddress}:4840"
    ],
    "SecurityPolicies": [
      {
        "Name": "Basic256Sha256",
        "Enabled": true
      },
      {
        "Name": "Aes128Sha256RsaOaep",
        "Enabled": true
      },
      {
        "Name": "None",
        "Enabled": true
      }
    ],
    "UserTokens": [
      {
        "Type": "Anonymous",
        "Enabled": true
      },
      {
        "Type": "UserName",
        "Enabled": true
      }
    ],
    "MaxSessions": 100,
    "MaxSubscriptionsPerSession": 200,
    "MaxMonitoredItemsPerSubscription": 1000,
    "MaxNodesPerRead": 1000,
    "MaxNodesPerWrite": 1000,
    "MaxNodesPerBrowse": 1000,
    "PublishingInterval": 500,
    "SamplingInterval": 250,
    "SessionTimeout": 300,
    "MinPublishingInterval": 100,
    "MaxPublishingInterval": 60000,
    "MinSamplingInterval": 100,
    "MaxSamplingInterval": 60000,
    "QueueSize": 10,
    "DiscardOldest": true,
    "DataChangeFilter": {
      "Enabled": true,
      "DeadbandType": "Absolute",
      "DeadbandValue": 0.1
    },
    "EventNotifier": {
      "Enabled": true,
      "QueueSize": 100
    }
  },
  "Metrics": {
    "Enabled": true,
    "Port": 5000,
    "Path": "/metrics",
    "Collectors": {
      "Process": true,
      "GC": true,
      "JIT": true,
      "Threading": true,
      "Http": true,
      "OPC": true
    },
    "OPCMetrics": {
      "Sessions": true,
      "Subscriptions": true,
      "MonitoredItems": true,
      "Requests": true,
      "Errors": true,
      "Latency": true
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "Port": 5000,
    "Path": "/health",
    "UI": {
      "Enabled": true,
      "Path": "/health-ui"
    },
    "Endpoints": [
      {
        "Name": "self",
        "Uri": "/health/self"
      },
      {
        "Name": "opc",
        "Uri": "/health/opc"
      },
      {
        "Name": "database",
        "Uri": "/health/database"
      }
    ],
    "EvaluationTimeInSeconds": 30,
    "MinimumSecondsBetweenFailureNotifications": 60
  },
  "Caching": {
    "Enabled": true,
    "DefaultExpiration": 300,
    "SizeLimit": 10000,
    "CompactionPercentage": 0.05,
    "OPCNodeCache": {
      "Enabled": true,
      "Expiration": 600,
      "SizeLimit": 5000
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "GlobalRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 100
      }
    ],
    "OPCRules": [
      {
        "Operation": "Read",
        "Period": "1s",
        "Limit": 50
      },
      {
        "Operation": "Write",
        "Period": "1s",
        "Limit": 20
      },
      {
        "Operation": "Browse",
        "Period": "1s",
        "Limit": 30
      }
    ]
  },
  "Security": {
    "Cors": {
      "Enabled": true,
      "AllowedOrigins": ["*"],
      "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "AllowedHeaders": ["*"],
      "AllowCredentials": true
    },
    "Headers": {
      "XFrameOptions": "DENY",
      "XContentTypeOptions": "nosniff",
      "XXSSProtection": "1; mode=block",
      "StrictTransportSecurity": "max-age=31536000; includeSubDomains",
      "ContentSecurityPolicy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    },
    "Authentication": {
      "Jwt": {
        "Enabled": false,
        "Issuer": "https://computehub.com",
        "Audience": "computehub-opc",
        "Secret": "change-this-in-production",
        "Expiration": 3600
      },
      "ApiKey": {
        "Enabled": false,
        "Keys": ["change-this-in-production"]
      }
    }
  },
  "Database": {
    "Type": "Sqlite",
    "ConnectionString": "Data Source=data/computehub-opc.db",
    "AutoMigrate": true,
    "RetryCount": 3,
    "RetryDelay": 1000,
    "CommandTimeout": 30
  },
  "BackgroundServices": {
    "SessionCleanup": {
      "Enabled": true,
      "Interval": 300,
      "InactiveTimeout": 600
    },
    "Statistics": {
      "Enabled": true,
      "Interval": 60,
      "Retention": 86400
    },
    "HealthCheck": {
      "Enabled": true,
      "Interval": 30
    }
  },
  "Telemetry": {
    "Enabled": true,
    "ApplicationInsights": {
      "ConnectionString": "",
      "EnableAdaptiveSampling": true,
      "EnablePerformanceCounterCollection": true,
      "EnableDependencyTracking": true
    },
    "Console": {
      "Enabled": true,
      "Level": "Information"
    }
  }
}