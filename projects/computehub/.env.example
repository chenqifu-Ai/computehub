# ==============================================================
# ComputeHub — 环境变量配置
# 复制为 .env 后修改
# ==============================================================

# 版本
COMPUTEHUB_VERSION=v0.7.0

# Gateway
GATEWAY_PORT=8282

# 时区
TZ=Asia/Shanghai

# 运行环境
COMPUTEHUB_ENV=production

# 资源限制 (Gateway)
COMPUTEHUB_CPU_LIMIT=4.0
COMPUTEHUB_CPU_RESERVATION=0.5
COMPUTEHUB_MEM_LIMIT=4G
COMPUTEHUB_MEM_RESERVATION=512M

# Prometheus (可选 profile: monitoring)
PROMETHEUS_PORT=9090

# Grafana (可选 profile: monitoring)
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin
